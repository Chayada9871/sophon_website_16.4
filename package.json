{
  "name": "sophon-web-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:public": "npm run dev --workspace @sophon/public-site",
    "dev:staff": "npm run dev --workspace @sophon/staff-site",
    "build:public": "npm run build --workspace @sophon/public-site",
    "build:staff": "npm run build --workspace @sophon/staff-site"
  }
}
